# ===============================================
# ForkLens Configuration Template
# ===============================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# HuggingFace API Configuration
# ===============================================
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Qdrant Vector Database Configuration  
# ===============================================
# Sign up at: https://cloud.qdrant.io/
# Create a cluster and get your credentials
QDRANT_HOST=https://your-cluster-id.region.gcp.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Model Configuration
# ===============================================
# Change these to swap out models without touching any code
LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
EMBED_MODEL=all-MiniLM-L6-v2
EMOTION_MODEL_PATH=./final_models/emotion_model

# Optional: Application Settings
# ===============================================
# VERBOSE_MODE=True
# COLLECTION_NAME=gutenbergbooks
# MAX_EXAMPLES=5